{
  "name": "dv-prototype",
  "version": "0.1.0",
  "description": "D / V — минимальный прототип (первый срез): канат света/тьмы + экономика хила",
  "type": "module",
  "private": true,
  "scripts": {
    "sim": "node tools/run-sim.js",
